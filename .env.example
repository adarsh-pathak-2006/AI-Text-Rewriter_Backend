# Google Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Django Configuration
DEBUG=False
ALLOWED_HOSTS=your-app-name.onrender.com,127.0.0.1,localhost

# Database Configuration
# Optional: SQLite will be used locally if omitted. 
# Render automatically injects this if you attach a PostgreSQL database.
# DATABASE_URL=postgres://user:password@hostname:port/dbname